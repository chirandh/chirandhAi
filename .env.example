ENVIRONMENT=development
API_KEYS=dev-insecure-key-change-me
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=
LLM_MODEL_PROPOSE=gpt-4o-mini
LLM_MODEL_SCORE=gpt-4o-mini
MAX_PROPOSE_ROUNDS_PER_SESSION=5
# Inside Docker: use http://minio:9000 for uploads; set S3_PRESIGN_ENDPOINT_URL for browser downloads.
S3_ENDPOINT_URL=http://localhost:9000
# Optional: public base URL for presigned GET (e.g. http://localhost:9000 when MinIO is mapped to host 9000)
S3_PRESIGN_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET=resume-artifacts
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123456
ARTIFACT_URL_TTL_SECONDS=3600
ARTIFACT_RETENTION_DAYS=14
RATE_LIMIT_DEFAULT=60/minute
CORS_ORIGINS=
TECTONIC_TIMEOUT_SECONDS=60
LOG_LEVEL=INFO

# UI: docker compose → http://localhost:3000 (nginx proxies /sessions, /jobs, /artifacts to API)
# Local dev UI: cd frontend && npm install && npm run dev → http://localhost:5173 (Vite proxies API paths)
